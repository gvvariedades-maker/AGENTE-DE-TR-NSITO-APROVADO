      {
        "id": "lei2",
        "titulo": "Art. 29, §2º — dispositivo da responsabilidade",
        "secao": "lei",
        "tipo": "trecho_legal",
        "conteudo": {
          "fonte": "CTB art. 29, §2º",
          "texto": "Respeitadas as normas de circulação e conduta estabelecidas neste artigo, em ordem decrescente, os veículos de maior porte serão sempre responsáveis pela segurança dos menores, os motorizados pelos não motorizados e, juntos, pela incolumidade dos pedestres.",
          "trechos_grifados": [
