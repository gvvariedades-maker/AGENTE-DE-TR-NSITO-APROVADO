# Supabase — copie para .env.local e preencha com os valores do dashboard
# https://supabase.com/dashboard/project/_/settings/api
#
# Auth do app: e-mail + senha (Supabase → Authentication → Providers → Email).
# Cadastro em /cadastro; recuperação em /esqueci-senha → /nova-senha.
# Redirect URLs em Authentication → URL Configuration devem incluir
# https://seu-dominio/auth/callback e http://localhost:3000/auth/callback

# URL pública do app (auth callbacks, e-mail de recuperação)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# Database — senha em texto puro (recomendado; encoding automático na URL)
# Rode: npm run setup:supabase-db  (sincroniza senha + service_role via Supabase CLI)
SUPABASE_PROJECT_REF=seu-project-ref
DATABASE_PASSWORD=sua-senha-postgres

# Opcional — host do pooler (default: aws-1-us-east-2.pooler.supabase.com)
# DATABASE_HOST=aws-0-[region].pooler.supabase.com

# Porta do pooler Supabase:
# - 6543 = transaction mode (padrão do app e scripts; use com npm run dev + seed)
# - 5432 = session mode (limite baixo de conexões; pode gerar EMAXCONNSESSION)
# DATABASE_PORT=6543

# Opcional — gerada automaticamente por setup:supabase-db
# Se usar DATABASE_URL manual, prefira :6543 no host pooler.supabase.com
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Scripts locais (NUNCA expor no client) — preenchida por setup:supabase-db
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
