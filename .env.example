# Supabase — copie para .env.local e preencha com os valores do dashboard
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# Database — Connection string (Settings > Database > Connection string > URI)
# Use "Transaction" pooler para serverless (Vercel)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Opcional — scripts de seed locais (NUNCA expor no client)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Project ID para MCP (.cursor/mcp.json) e referência
SUPABASE_PROJECT_REF=seu-project-ref
